FINNHUB_API_KEY=
NEWSAPI_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: base URL of the backend API, used to persist the digest for the dashboard's history page
BACKEND_API_URL=
# Optional: must match the backend's DIGEST_API_SECRET env var; leave blank if the backend has none set
DIGEST_API_SECRET=
# Optional: number of articles to fetch from each source (default 10)
FINNHUB_LIMIT=10
NEWSAPI_LIMIT=10
