# App ID from a registered app at https://developers.deriv.com/ (Register Application).
# Must be your own registered app's ID, not Deriv's public test app_id (1089) --
# the new REST API used here rejects that with "Invalid application".
DERIV_APP_ID=
# API token generated at https://app.deriv.com/account/api-token (or the same page
# under developers.deriv.com's dashboard -- they list the same tokens).
# Needs all 4 scopes checked (Trade, Account management, Application insights,
# Payments) -- narrower combinations were tested and rejected with 403 on this
# account; the exact minimal set wasn't determined. Use a demo account token first
# when testing locally, if your account has one.
DERIV_API_TOKEN=
# Your Deriv loginid (shown in the API Playground's "accounts" endpoint response,
# or in the Deriv app account switcher). Matches ^[A-Z]+[0-9]+$, e.g. CR6782045.
DERIV_LOGINID=
# Base URL of the backend API (same value used by news_bot)
BACKEND_API_URL=
# Must match the backend's BROKER_SYNC_SECRET env var; leave blank if the backend has none set
BROKER_SYNC_SECRET=
# How many days back to pull transactions each run (default 2; overlap is fine, dedup is server-side)
DERIV_SYNC_LOOKBACK_DAYS=2
